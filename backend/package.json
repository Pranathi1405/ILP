{
  "name": "ilp-backend",
  "version": "1.0.0",
  "description": "Interactive Learning Portal – Backend API (Intern Batch 04)",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand src/tests/unit",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand src/tests/integration",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --coverage",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --watch",
    "migrate": "node scripts/migrate.js",
    "migrate:rollback": "node scripts/migrate.js rollback",
    "seed": "node scripts/seed.js",
    "docker:build": "docker build -t ilp-backend .",
    "docker:up": "docker-compose -f docker/docker-compose.yaml up",
    "docker:down": "docker-compose -f docker/docker-compose.yaml down",
    "build": "npm run lint && npm run test"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@zegocloud/zego-uikit-prebuilt": "^2.17.3",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "bullmq": "^5.71.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cron": "^4.4.0",
    "dayjs": "^1.11.19",
    "dotenv": "^16.6.1",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.2",
    "express-useragent": "^2.1.0",
    "express-validator": "^7.1.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "mysql2": "^3.9.2",
    "node": "^22.22.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.18.0",
    "puppeteer": "^24.40.0",
    "rate-limit-redis": "^4.3.1",
    "rate-limiter-flexible": "^11.0.0",
    "razorpay": "^2.9.6",
    "redis": "^5.11.0",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ua-parser-js": "^2.0.9",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zego-zim-web": "^2.28.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "nodemonConfig": {
    "watch": [
      "src",
      "server.js"
    ],
    "ext": "js,json",
    "ignore": [
      "src/tests/**",
      "logs/**",
      "uploads/**"
    ],
    "delay": 500
  }
}
